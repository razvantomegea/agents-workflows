{
  "permissions": {
    "defaultMode": "default",
    "allow": [
<% permissions.forEach(function(permission, i) { -%>
      <%- jsonString(permission) %><%= i < permissions.length - 1 ? ',' : '' %>
<% }); -%>
    ],
    "deny": [
<% denyList.forEach(function(pattern, i) { -%>
      <%- jsonString(pattern) %><%= i < denyList.length - 1 ? ',' : '' %>
<% }); -%>
    ]
  },
  "sandbox": {
    "mode": "workspace-write",
    "autoAllowBashIfSandboxed": true,
    "allowedDomains": [
      "api.github.com",
      "registry.npmjs.org",
      "nodejs.org",
      "raw.githubusercontent.com",
      "objects.githubusercontent.com",
      "pypi.org",
      "files.pythonhosted.org"
    ]
  }<% if (postToolUseHooks.length > 0 || preToolUseHooks.length > 0) { %>,
  "hooks": {
<% if (preToolUseHooks.length > 0) { -%>
    "PreToolUse": [
<% preToolUseHooks.forEach(function(hookEntry, i) { -%>
      {
        "matcher": <%- jsonString(hookEntry.matcher) %>,
        "hooks": [
<% hookEntry.hooks.forEach(function(commandHook, hookIndex) { -%>
          { "type": <%- jsonString(commandHook.type) %>, "command": <%- jsonString(commandHook.command) %> }<%= hookIndex < hookEntry.hooks.length - 1 ? ',' : '' %>
<% }); -%>
        ]
      }<%= i < preToolUseHooks.length - 1 ? ',' : '' %>
<% }); -%>
    ]<%= postToolUseHooks.length > 0 ? ',' : '' %>
<% } -%>
<% if (postToolUseHooks.length > 0) { -%>
    "PostToolUse": [
<% postToolUseHooks.forEach(function(hookEntry, i) { -%>
      {
        "matcher": <%- jsonString(hookEntry.matcher) %>,
        "hooks": [
<% hookEntry.hooks.forEach(function(commandHook, hookIndex) { -%>
          { "type": <%- jsonString(commandHook.type) %>, "command": <%- jsonString(commandHook.command) %> }<%= hookIndex < hookEntry.hooks.length - 1 ? ',' : '' %>
<% }); -%>
        ]
      }<%= i < postToolUseHooks.length - 1 ? ',' : '' %>
<% }); -%>
    ]
<% } -%>
  }<% } %>
}
