# Project-scoped forbid/allow rules for Codex CLI.
# See PRD §1.9 and §1.9.1 for rationale. Every rule below must remain in place
# under both interactive and non-interactive postures.

# --- Forbidden: destructive git ---------------------------------------------

prefix_rule(
  pattern = ["git", ["push", "commit"]],
  decision = "forbidden",
  justification = "No remote pushes or commits from the agent",
)

prefix_rule(
  pattern = ["git", "commit", "--amend"],
  decision = "forbidden",
  justification = "No commit rewrites",
)

prefix_rule(
  pattern = ["git", "reset", ["--hard", "--merge"]],
  decision = "forbidden",
  justification = "No destructive history ops",
)

prefix_rule(
  pattern = ["git", "clean", ["-f", "-fd"]],
  decision = "forbidden",
  justification = "No forced cleans",
)

prefix_rule(
  pattern = ["git", "branch", "-D"],
  decision = "forbidden",
  justification = "No force branch deletes",
)

prefix_rule(
  pattern = ["git", "rm"],
  decision = "forbidden",
  justification = "No index removes from the agent",
)

# --- Forbidden: Unix destructive & privilege -------------------------------

prefix_rule(
  pattern = [["rm", "sudo"]],
  decision = "forbidden",
  justification = "Block rm and sudo entirely",
)

# --- Forbidden: Windows-native destructive (E9.T10) ------------------------

prefix_rule(
  pattern = [["Remove-Item", "Remove-ItemProperty", "ri", "del", "erase", "rmdir", "rd"]],
  decision = "forbidden",
  justification = "Destructive file removal; use editor/Git instead.",
)

# --- Forbidden: publish & infra --------------------------------------------

prefix_rule(
  pattern = [["pnpm", "npm", "yarn", "cargo"], "publish"],
  decision = "forbidden",
  justification = "No package publishing",
)

prefix_rule(
  pattern = ["twine", "upload"],
  decision = "forbidden",
  justification = "No PyPI publishes",
)

prefix_rule(
  pattern = ["terraform", ["apply", "destroy"]],
  decision = "forbidden",
  justification = "No infra changes",
)

prefix_rule(
  pattern = ["kubectl", ["apply", "delete"]],
  decision = "forbidden",
  justification = "No cluster changes",
)

# --- Forbidden: network egress & exfil (E9.T11) ---------------------------
# Plain `curl` and `wget` are intentionally NOT forbidden here: read-only
# fetches (e.g., `curl https://api.github.com/...`) have legitimate utility
# and are allowed by both Claude and Codex per PRD E9.T11. Only the Windows
# `.exe` variants and PowerShell exfiltration helpers are forbidden because
# they are the primary prompt-injection exfil surface on Windows.

prefix_rule(
  pattern = [["Invoke-WebRequest", "iwr", "Invoke-RestMethod", "irm", "curl.exe", "wget.exe"]],
  decision = "forbidden",
  justification = "Exfiltration surface; raw sockets via node -e / python -c remain uncovered (§1.9.1 item 10.5).",
)

# --- Forbidden: shell wrapper bypass (E9.T12) ------------------------------
# pwsh/cmd wrappers tokenize the script body as one opaque string so prefix_rule
# cannot match inside. Use `pwsh -File <script.ps1>` for auditable scripts.

prefix_rule(
  pattern = [["pwsh", "pwsh.exe", "powershell", "powershell.exe"], ["-Command", "-c", "-EncodedCommand"]],
  decision = "forbidden",
  justification = "Script-body is opaque to prefix_rule; use -File <script.ps1> for auditable scripts.",
)

prefix_rule(
  pattern = [["cmd", "cmd.exe"], ["/c", "/k"]],
  decision = "forbidden",
  justification = "cmd wrapper tokenizes script body; use an explicit script file.",
)

# --- Allow: Node/TS toolchain (explicit safe entrypoints only) -------------

prefix_rule(
  pattern = [["pnpm", "npm", "yarn"], ["test", "lint", "check-types", "build", "install", "add", "remove", "up"]],
  decision = "allow",
  justification = "Package-manager operations scoped to vetted subcommands",
)

prefix_rule(
  pattern = ["npx", ["agents-workflows", "tsc", "tsx", "vitest", "jest", "eslint", "prettier"]],
  decision = "allow",
  justification = "npx only for vetted local toolchain entrypoints",
)

prefix_rule(
  pattern = ["node", ["dist/index.js", "scripts/build.mjs", "--version", "-v"]],
  decision = "allow",
  justification = "Node runtime only for vetted local entrypoints",
)

prefix_rule(
  pattern = [["tsc", "tsx", "vitest", "jest", "eslint", "prettier"]],
  decision = "allow",
  justification = "Direct toolchain binaries",
)

# --- Allow: Python toolchain (explicit safe entrypoints only) --------------

prefix_rule(
  pattern = [["pip"], ["install", "list", "show", "freeze"]],
  decision = "allow",
  justification = "pip scoped to non-destructive package operations",
)

prefix_rule(
  pattern = [["python", "python3"], ["--version", "-V"]],
  decision = "allow",
  justification = "Python runtime limited to version checks",
)

# --- Allow: Local / read-only git subcommands -----------------------------

prefix_rule(
  pattern = ["git", ["status", "diff", "log", "branch", "add", "checkout", "switch", "stash", "pull"]],
  decision = "allow",
  justification = "Local / read-only git (symmetric with Claude LOCAL_GIT_ALLOWS)",
)
