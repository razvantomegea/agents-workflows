{
  "permissions": {
    "allow": [
      "Edit(./**)",
      "MultiEdit(./**)",
      "Write(./**)",
      "Bash(pnpm check-types:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm lint --fix:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm --force:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(twine upload:*)",
      "Bash(terraform apply:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete namespace:*)",
      "Edit(.env*)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(migrations/**)",
      "Write(.env*)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(migrations/**)",
      "MultiEdit(.env*)",
      "MultiEdit(**/*.key)",
      "MultiEdit(**/*.pem)",
      "MultiEdit(migrations/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint --fix || true"
          }
        ]
      }
    ]
  }
}