  "sandbox": {
    "mode": "workspace-write",
    "autoAllowBashIfSandboxed": true,
    "allowedDomains": [
      "api.github.com",
      "registry.npmjs.org",
      "nodejs.org",
      "raw.githubusercontent.com",
      "objects.githubusercontent.com",
      "pypi.org",
      "files.pythonhosted.org"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
