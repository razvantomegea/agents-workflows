      "Bash(rm -r:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm --force:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --merge:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git commit --amend:*)",
      "Bash(git rm:*)",
      "Bash(sudo:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(twine upload:*)",
      "Bash(terraform apply:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(Invoke-WebRequest:*)",
      "Bash(iwr:*)",
      "Bash(Invoke-RestMethod:*)",
      "Bash(irm:*)",
      "Bash(curl.exe:*)",
      "Bash(wget.exe:*)",
      "Bash(pwsh:*)",
      "Bash(pwsh.exe:*)",
      "Bash(powershell:*)",
      "Bash(powershell.exe:*)",
      "Bash(cmd /c:*)",
      "Bash(cmd /k:*)",
      "Bash(cmd.exe /c:*)",
      "Bash(cmd.exe /k:*)",
      "Bash(node -e:*)",
      "Bash(node --eval:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(curl* | sh)",
      "Bash(curl* | bash)",
      "Bash(wget* | sh)",
      "Bash(wget* | bash)",
      "Edit(/**)",
      "Edit(~/**)",
      "Write(/**)",
      "Write(~/**)",
      "MultiEdit(/**)",
      "MultiEdit(~/**)",
      "Edit(.env*)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(migrations/**)",
      "Write(.env*)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(migrations/**)",
      "MultiEdit(.env*)",
      "MultiEdit(**/*.key)",
      "MultiEdit(**/*.pem)",
      "MultiEdit(migrations/**)"
