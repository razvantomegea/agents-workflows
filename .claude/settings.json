      "MultiEdit(./**)",
      "Write(./**)",
      "Bash(pnpm:*)",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(tsc:*)",
      "Bash(jest:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)"
