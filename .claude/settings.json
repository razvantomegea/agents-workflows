\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)cargo publish([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)twine upload([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)terraform apply([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)kubectl apply([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)kubectl delete([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)invoke-webrequest[A-Za-z]*([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)iwr([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)invoke-restmethod[A-Za-z]*([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)irm([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)curl\\\\.exe([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)wget\\\\.exe([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)pwsh([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)pwsh\\\\.exe([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)powershell([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)powershell\\\\.exe([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)cmd /c([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)cmd /k([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)cmd\\\\.exe /c([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)cmd\\\\.exe /k([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)node -e[A-Za-z]*([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)node --eval[A-Za-z]*([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)python -c[A-Za-z]*([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|(^|[[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&)python3 -c[A-Za-z]*([[:space:]]|;|\\\\||&|\\\\(|\\\\)|<|>|\\\\|\\\\||&&|$)|curl .*\\\\| *sh|curl .*\\\\| *bash|wget .*\\\\| *sh|wget .*\\\\| *bash\"\nif printf '%s\\n%s' \"$cmd\" \"$normalized_cmd\" | grep -qE \"$patterns\"; then\n  printf '%s\\n' \"Blocked: destructive command matched guard pattern.\" >&2\n  exit 2\nfi\nexit 0" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          { "type": "command", "command": "pnpm lint --fix || true" }
        ]
      }
    ]
  }
}
