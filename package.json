{
  "name": "agents-workflows",
  "version": "0.1.8",
  "description": "Reusable AI agent configuration framework — install battle-tested Claude Code agents, Codex skills, and workflow commands into any project",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "bin": {
    "agents-workflows": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "check-types": "tsc --noEmit",
    "lint": "oxlint . --fix",
    "format": "prettier --write .",
    "publish:check": "corepack pnpm build && npm pack --dry-run",
    "publish:public": "npm version patch --no-git-tag-version && corepack pnpm publish:check && npm publish --access public --ignore-scripts",
    "prepublishOnly": "corepack pnpm build"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai-agents",
    "workflow",
    "scaffolding",
    "cli"
  ],
  "author": "Razvan Tomegea",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/razvantomegea/agents-workflows.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "diff": "^7.0.0",
    "ejs": "^3.1.10",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/ejs": "^3.1.5",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "oxlint": "^0.12.0",
    "ts-jest": "^29.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
